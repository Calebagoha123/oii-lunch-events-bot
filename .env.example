# --- Which channel(s) to post to ---
# Comma-separated. Default is "teams". Use "teams,whatsapp" to run both during
# the migration, or "whatsapp" for the deprecated WhatsApp-only mode.
SENDERS=teams

# --- Teams (default sender) ---
# Power Automate workflow webhook URL. In the target channel:
#   ⋯ → Workflows → "Post to a channel when a webhook request is received".
# (The old Office 365 "Incoming Webhook" connector was retired by Microsoft in
# May 2026 and is no longer an option.)
TEAMS_WEBHOOK_URL=

# --- WhatsApp (DEPRECATED — remove once everyone is on Teams) ---
GROUP_NAME=            # Exact WhatsApp group name to send menus to

# --- Menu sources (Gmail + Claude Vision) ---
GMAIL_USER=            # Gmail address that receives the Blavatnik/Schwarzman menu emails
GMAIL_APP_PASSWORD=    # Gmail App Password (requires 2FA enabled)
ANTHROPIC_API_KEY=     # Anthropic API key for Claude Vision image parsing

# --- Alerting (opens a GitHub issue on the repo when a source/send fails) ---
GITHUB_REPO=           # owner/name of the bot's repo, e.g. Calebagoha123/oii-lunch-events-bot
GITHUB_TOKEN=          # Token with issues:write on that repo. Alerts silently no-op if unset.
